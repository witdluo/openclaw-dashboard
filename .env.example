# OpenClaw Dashboard 环境变量配置

# ===========================================
# OpenClaw 配置路径
# ===========================================
# OpenClaw 配置目录（默认 ~/.openclaw）
OPENCLAW_PATH=/Users/wit/.openclaw

# ===========================================
# 服务端口配置
# ===========================================
# 后端 API 端口
API_PORT=3100

# 前端开发服务器端口
FRONTEND_PORT=3000

# ===========================================
# 可选配置
# ===========================================
# 数据刷新间隔（毫秒）
REFRESH_INTERVAL=5000

# 消息显示数量限制
MESSAGES_LIMIT=100

# Agent 活跃判断时间（分钟）
ACTIVE_THRESHOLD_MINUTES=5